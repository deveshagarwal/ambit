# AI provider (DeepSeek by default, OpenAI-compatible). App runs with deterministic
# fallbacks if no key is set, but matching/onboarding are far better with a real key.
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# Production database. When set, the app uses this hosted Postgres (Vercel Postgres
# or Neon). When unset, it falls back to local PGlite in ./data/weave-pg.
# Vercel Postgres injects POSTGRES_URL automatically; either name works.
DATABASE_URL=

# Auth (Clerk). REQUIRED: the app 500s without these because the middleware runs
# clerkMiddleware on every request. Get them from the Clerk dashboard. Use live
# keys (pk_live_/sk_live_) in production, not the pk_test_/sk_test_ dev keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Demo sandbox. Set to 1 ONLY in a throwaway/demo environment to enable the
# "act as" member picker and the reseed button. Leave UNSET in production: when
# off, nobody can impersonate members or wipe the seeded community.
AMBIT_SANDBOX=

# Admin secret for the invite loop. Set to a long random string, then send it as
# the x-admin-secret header to GET/POST /api/admin/invites (read the waitlist,
# mint invite codes). If unset, that admin surface is fully closed.
ADMIN_SECRET=

# Exa.ai search API. Powers the admin "find people on LinkedIn" sourcing tool at
# /admin (Requests tab). Get a key at https://exa.ai. If unset, the sourcing
# action reports "not configured" and the rest of admin still works.
EXA_API_KEY=
